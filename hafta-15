<!DOCTYPE html>
<html lang="en">
<head>
</head>
<body>
<?php
function bolme($bolunen, $bolen){
    if (bolen==0)
        throw new Exception("Sıfıra bölme hatası");
    
    return $bolunen / $bolen;
}
try{
    echo bolme(20,0);
    echo "İstisna sonrası kodlar";
}catch(Exception $ex){
    echo $ex->getMessage();
}
echo " <br>Program devam eder";
    ?>

</body>
</html>

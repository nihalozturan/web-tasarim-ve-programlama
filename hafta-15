<!DOCTYPE html>
<html lang="en">
<head>
</head>
<body>
<?php
try{
    $conn = new PDO("mysql:host=localhost;dbname=ogrenci","root","");
    $conn->setAttribute(PDO::ATTR_ERRMODE,PDO::ERRMODE_EXCEPTION);
   $sql = "SELECT * FROM uyelik";
   $stmt = $conn->prepare($sql);
   $stmt->execute();
   $kayitlar =$stmt->fetchAll();
   echo "<table>";
   echo "<tr>";
   echo "<td>ID</td>";
   echo"<td>Ad</td>";
   echo"<td>Soyad</td>";
   echo"<td>email</td>";
   echo"<td>KullaniciAdi</td>";
   echo"<td>Tarih</td>";
   echo "</tr>";
foreach($kayitlar as $kayit){
echo "<tr>";  
echo "<td>".$kayit["id"]."</td>";
echo "<td>".$kayit["ad"]."</td>";
echo "<td>".$kayit["soyad"]."</td>";
echo "<td>".$kayit["email"]."</td>";
echo "<td>".$kayit["kullanici"]."</td>";
echo "<td>".$kayit["tarih"]."</td>";
echo "</tr>";
echo "</table>";
}
}catch (PDOException $ex){
    echo $ex->getMessage();
}
    ?>

</body>
</html>

